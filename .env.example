# Polymarket API credentials (Settings > API Keys en polymarket.com)
POLYMARKET_KEY_ID=tu_key_id_aqui
POLYMARKET_SECRET_KEY=tu_secret_key_aqui
POLYMARKET_PASSPHRASE=

# Para trading REAL: private key de la wallet Ethereum que usas en Polymarket
# IMPORTANTE: Usa una wallet DEDICADA solo para este bot, no tu wallet principal
# Cómo obtenerla: MetaMask > ... > Account Details > Export Private Key
# Formato: 0x seguido de 64 caracteres hex
POLYMARKET_PRIVATE_KEY=

# Tu dirección de wallet (opcional si pones private key, se deriva automáticamente)
POLYMARKET_WALLET_ADDRESS=

# Configuración del bot
DAILY_BUDGET=65
STAKE_PER_TRADE=3
MIN_ODDS=0.70
MAX_ODDS=0.92
MIN_LIQUIDITY=500
PORT=3002

# ── VALUE BETTING (comparar .us vs casas de apuestas) ──
# Key GRATIS en https://the-odds-api.com (registro de 30s, 500 requests/mes gratis)
# Sin esta key, el motor de value queda apagado.
ODDS_API_KEY=
# Deportes a comparar (opcional; cada uno = 1 crédito por refresco, refresco cada 6h)
ODDS_SPORTS=baseball_mlb,basketball_nba,icehockey_nhl,soccer_fifa_world_cup
# Minutos entre refrescos de odds (default 360 = 6h para no agotar el tier gratis)
ODDS_REFRESH_MIN=360
